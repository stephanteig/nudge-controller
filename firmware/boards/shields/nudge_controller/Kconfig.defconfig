# Default Kconfig values applied whenever the Nudge Controller shield is built.
# Users can still override any of these in firmware/nudge_controller.conf.

if SHIELD_NUDGE_CONTROLLER

config ZMK_KEYBOARD_NAME
    # BLE advertises this name (max 16 chars). "Nudge Controller" is exactly 16.
    default "Nudge Controller"

# Pull in the rotary-encoder driver + ZMK's keymap-sensor (encoder) support so a
# plain `west build` for this shield works without extra flags.
config EC11
    default y

config ZMK_ENCODER
    default y

endif # SHIELD_NUDGE_CONTROLLER
